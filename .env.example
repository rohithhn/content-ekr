# ContentEngine — Environment Variables
# Copy this to .env.local and fill in your API keys

# Anthropic (Claude Opus 4.6 — text generation)
ANTHROPIC_API_KEY=

# OpenAI (GPT-5.4 / DALL·E — image generation)
OPENAI_API_KEY=

# Nano Banana (image generation)
NANOBANANA_API_KEY=

# Kling / Kuaishou (video generation)
KLING_API_KEY=

# Optional: Override base URLs for self-hosted/proxy setups
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
