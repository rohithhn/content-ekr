# ContentEngine — Environment Variables
# Copy this to .env.local and fill in your API keys

# Anthropic (Claude Opus 4.6 — text generation)
ANTHROPIC_API_KEY=

# OpenAI (chat + GPT Image 1.5 via images.generate — not DALL·E)
OPENAI_API_KEY=

# Google Gemini (optional — Content Studio image engine + visual brief when selected; AI Studio key)
# GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=

# Nano Banana 2 — image generation (Bearer key from https://nanobananaapi.ai/api-key ; api.nanobananaapi.ai)
NANOBANANA_API_KEY=

# Kling / Kuaishou (video generation)
KLING_API_KEY=

# Notion OAuth (real connector)
# 1) Create a public Notion integration with OAuth enabled
# 2) Redirect URI must point to /api/notion/callback on this app
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/notion/callback

# Optional: Override base URLs for self-hosted/proxy setups
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
